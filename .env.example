# Convex environment variables
# Set via: npx convex env set KEY "value"

# Cloudflare R2 credentials (if using R2 instead of Convex storage)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=aaac-super-feeds

# Public base URL for feed links and WebSub pinging
# This is your Convex HTTP site URL (replace <deployment> with your deployment name)
FEED_BASE_URL=https://<deployment>.convex.site
